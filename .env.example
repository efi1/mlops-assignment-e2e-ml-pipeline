# ---- Inference (Nebius Token Factory) ----
NEBIUS_API_KEY=your-token-factory-key-here

# ---- Object storage (S3-compatible: local MinIO or Nebius Object Storage) ----
# Host-side ports (the container-internal ports are fixed: 9000 API / 9001 console)
S3_API_PORT=9000
S3_CONSOLE_PORT=9001
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=agent-eval-runs
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
# change for security purposes
S3_SECRET_KEY=minioadmin

# ---- MLflow tracking ----
# Host-side UI port (container-internal port is fixed to 5000)
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://mlflow:5000

# ---- Airflow ----
# Admin login for the Airflow UI (used by the compose setup)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# Host-side UI port (container-internal port is fixed to 8080)
AIRFLOW_PORT=8080

# ---- Docker execution (Phase 3) ----
# HOST_PROJECT_ROOT is the repo path ON THE HOST (used for DockerOperator mounts).
HOST_PROJECT_ROOT=/home/youruser/mlops-assignment-e2e-ml-pipeline
TASK_IMAGE=agent-eval:latest
DOCKER_URL=unix://var/run/docker.sock
